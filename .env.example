# Gemini API Key (Required for LLM capabilities)
# Get a free API key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Custom Search API credentials
# If left commented out, the application will default to DuckDuckGo Search (which is completely free and needs no key)
# GOOGLE_API_KEY=your_google_search_api_key_here
# GOOGLE_CSE_ID=your_custom_search_engine_id_here
